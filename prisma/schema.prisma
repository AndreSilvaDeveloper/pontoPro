generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id                  String       @id @default(cuid())
  nome                String
  cnpj                String?
  criadoEm            DateTime     @default(now())
  configuracoes       Json?
  status              String       @default("ATIVO")
  intervaloPago       Boolean      @default(false)
  fluxoEstrito        Boolean      @default(true)
  matrizId            String?
  chavePix            String?      @default("118.544.546-33")
  diaVencimento       Int          @default(15)
  dataUltimoPagamento DateTime?
  adminsPermitidos    AdminLoja[]
  matriz              Empresa?     @relation("MatrizFilial", fields: [matrizId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  filiais             Empresa[]    @relation("MatrizFilial")
  feriados            Feriado[]
  usuarios            Usuario[]
  comunicados         Comunicado[]

  cobrancaAtiva Boolean   @default(false)
  trialAte      DateTime?
  pagoAte       DateTime?

  billingAnchorAt  DateTime? // âncora real do vencimento (recomendado)
  cobrancaWhatsapp String? // ex: "5532935005492"

  plano         String @default("PROFESSIONAL")
  billingCycle  String @default("MONTHLY")
  billingMethod String @default("UNDEFINED")

  asaasCustomerId       String?
  asaasSubscriptionId   String?
  asaasCurrentPaymentId String?
  asaasCurrentDueDate   DateTime?

  revendedorId String?
  revendedor   Revendedor? @relation(fields: [revendedorId], references: [id])

  // Modo Totem (addon — admin do SaaS ativa por empresa)
  addonTotem            Boolean       @default(false)
  rekognitionCollection String? // ID da coleção AWS Rekognition criada pra essa empresa
  totens                TotemDevice[]

  // Módulo Financeiro (addon — controla salário, descontos, folha)
  addonFinanceiro Boolean @default(false)

  // Preço negociado (override do preço de tabela do plano).
  // Quando definido e dentro da validade, substitui inteiramente o cálculo padrão.
  // expiraEm = null significa "sem prazo" (vigente até alterar manualmente).
  precoNegociado         Decimal?  @db.Decimal(10, 2)
  precoNegociadoMotivo   String?
  precoNegociadoExpiraEm DateTime?

  // Identidade visual da empresa (personalização do painel admin/funcionário)
  logoUrl      String?
  nomeExibicao String? // nome exibido na sidebar/header (fallback: nome)
  corPrimaria  String? @default("#7c3aed")
}

model Usuario {
  id                  String    @id @default(cuid())
  nome                String
  email               String    @unique
  senha               String
  tituloCargo         String?
  fotoPerfilUrl       String?
  jornada             Json?
  assinaturaUrl       String?
  cargo               String    @default("FUNCIONARIO")
  deveTrocarSenha     Boolean   @default(false)
  deveCadastrarFoto   Boolean   @default(false)
  rekognitionFaceId   String? // ID do rosto na coleção AWS Rekognition (1:N)
  empresaId           String?
  latitudeBase        Float     @default(0)
  longitudeBase       Float     @default(0)
  raioPermitido       Int       @default(100)
  pontoLivre          Boolean   @default(false)
  locaisAdicionais    Json?
  criadoEm            DateTime  @default(now())
  resetToken          String?   @unique
  resetTokenExpiry    DateTime?
  // Link de ativação (primeiro acesso do funcionário) — define a senha e já loga.
  ativacaoToken       String?   @unique
  ativacaoTokenExpiry DateTime?
  ipsPermitidos       String?
  telefone            String?
  modoValidacaoPonto  String    @default("GPS")
  temaPreferido       String    @default("dark") // dark | light | system

  // === 2FA (TOTP) ===
  twoFactorSecret      String? // base32 secret, só preenchido quando 2FA ativado
  twoFactorEnabled     Boolean             @default(false)
  twoFactorBackupCodes Json? // array de 10 códigos hash sha256 para recovery
  lojasPermitidas      AdminLoja[]
  ausencias            Ausencia[]
  pontos               Ponto[]
  solicitacoes         SolicitacaoAjuste[]
  horasExtras          HoraExtra[]
  empresa              Empresa?            @relation(fields: [empresaId], references: [id])

  deveDarCienciaCelular Boolean            @default(false)
  cpf                   String?
  pis                   String? // PIS/PASEP/NIS - usado no AFD (Portaria 671)
  cienciaCelularOpcao   String?
  cienciaCelularData    DateTime?
  cienciaCelularDocUrl  String?
  novidadesVisto        String?
  installPromptVisto    Boolean            @default(false)
  pushPromptVisto       Boolean            @default(false)
  pushSubscriptions     PushSubscription[]

  revendedorId      String?
  revendedor        Revendedor?        @relation(fields: [revendedorId], references: [id])
  ajustesBancoHoras AjusteBancoHoras[]
  contracheques     Contracheque[]

  fechamentosFuncionario Fechamento[] @relation("fechamento_funcionario")
  fechamentosCriados     Fechamento[] @relation("fechamento_admin")

  notificacoes Notificacao[] @relation("notif_destinatario")

  // === Módulo Financeiro (addon opcional, controlado pelo super admin) ===
  salarioBase       Decimal?         @db.Decimal(10, 2) // referência fixa (sugestão pra base de proventos do mês)
  descontosLancados Desconto[]       @relation("desconto_funcionario")
  descontosCriados  Desconto[]       @relation("desconto_criado_por")
  proventosLancados Provento[]       @relation("provento_funcionario")
  proventosCriados  Provento[]       @relation("provento_criado_por")
  folhasFuncionario FolhaPagamento[] @relation("folha_funcionario")
  folhasCriadas     FolhaPagamento[] @relation("folha_criada_por")
}

model Notificacao {
  id             String    @id @default(cuid())
  destinatarioId String?
  tipo           String
  prioridade     String    @default("NORMAL")
  titulo         String
  mensagem       String
  url            String?
  metadata       Json?
  lida           Boolean   @default(false)
  lidaEm         DateTime?
  criadoEm       DateTime  @default(now())
  destinatario   Usuario?  @relation("notif_destinatario", fields: [destinatarioId], references: [id], onDelete: Cascade)

  @@index([destinatarioId, lida, criadoEm])
  @@index([tipo, criadoEm])
}

model Plano {
  id                   String   @id // STARTER | PROFESSIONAL | ENTERPRISE
  nome                 String
  descricao            String
  preco                Decimal  @db.Decimal(10, 2)
  maxFuncionarios      Int
  maxAdmins            Int
  maxFiliais           Int // -1 = ilimitado
  extraFuncionario     Decimal  @db.Decimal(10, 2)
  extraAdmin           Decimal  @db.Decimal(10, 2)
  extraFilial          Decimal  @db.Decimal(10, 2)
  reconhecimentoFacial Boolean  @default(false)
  relatoriosPdf        String   @default("BASICO") // BASICO | COMPLETO
  suporte              String   @default("EMAIL") // EMAIL | WHATSAPP_EMAIL | PRIORITARIO
  totemIncluso         Boolean  @default(false)
  totemAddonMatriz     Decimal  @db.Decimal(10, 2)
  totemAddonFilial     Decimal  @db.Decimal(10, 2)
  ordem                Int      @default(0) // ordem de exibição na landing
  destaque             Boolean  @default(false) // marcar como "Mais popular" na landing
  visivel              Boolean  @default(true) // se exibe na landing
  atualizadoEm         DateTime @updatedAt
}

model Cupom {
  id             String     @id @default(cuid())
  codigo         String     @unique
  nome           String
  tipo           String // PERCENTUAL | VALOR_FIXO | MESES_GRATIS | TRIAL_ESTENDIDO
  valor          Decimal    @db.Decimal(10, 2)
  duracaoMeses   Int        @default(1) // quantas parcelas o desconto vale (-1 = sempre)
  descricao      String?
  ativo          Boolean    @default(true)
  visivelLanding Boolean    @default(false)
  destaque       String? // texto-chamariz curto na landing
  validoDe       DateTime?
  validoAte      DateTime?
  maxUsos        Int?
  usos           Int        @default(0)
  apenasNovos    Boolean    @default(false)
  apenasPlanos   String[] // vazio = todos os planos
  apenasCiclo    String? // null=todos | "MONTHLY" | "YEARLY"
  criadoEm       DateTime   @default(now())
  criadoPor      String?
  atualizadoEm   DateTime   @updatedAt
  usosRel        CupomUso[]

  @@index([ativo, codigo])
  @@index([visivelLanding, ativo])
}

model CupomUso {
  id                 String    @id @default(cuid())
  cupomId            String
  cupom              Cupom     @relation(fields: [cupomId], references: [id], onDelete: Cascade)
  empresaId          String
  parcelasAplicadas  Int       @default(0) // quantas parcelas já tiveram o desconto
  parcelasMax        Int       @default(1) // limite (espelha duracaoMeses do cupom no momento de aplicar)
  valorAplicadoTotal Decimal   @default(0) @db.Decimal(10, 2)
  ativadoEm          DateTime  @default(now())
  expiradoEm         DateTime?

  @@unique([cupomId, empresaId])
  @@index([empresaId])
}

model ConfigSistema {
  id           String   @id @default(cuid())
  chave        String   @unique
  valor        String   @db.Text
  tipo         String   @default("texto")
  descricao    String?
  categoria    String?  @default("geral")
  atualizadoEm DateTime @updatedAt

  @@index([categoria])
}

model Fechamento {
  id             String   @id @default(cuid())
  empresaId      String
  funcionarioId  String
  adminCriadorId String
  periodoInicio  DateTime
  periodoFim     DateTime
  status         String   @default("PENDENTE") // PENDENTE | ASSINADO | RECUSADO | CANCELADO

  // Snapshot do relatório no momento da geração
  // (struct: { resumo: {...}, dias: [...], geradoEm: ISO, empresaNome })
  snapshot Json

  // Quando o funcionário assina/recusa
  assinadoEm          DateTime?
  assinaturaUrl       String?
  ipAssinatura        String?
  userAgentAssinatura String?
  recusadoEm          DateTime?
  recusadoMotivo      String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  funcionario  Usuario @relation("fechamento_funcionario", fields: [funcionarioId], references: [id], onDelete: Cascade)
  adminCriador Usuario @relation("fechamento_admin", fields: [adminCriadorId], references: [id])

  @@index([empresaId, status])
  @@index([funcionarioId, status])
  @@index([periodoInicio, periodoFim])
}

model PushSubscription {
  id        String   @id @default(cuid())
  usuarioId String
  endpoint  String   @unique
  p256dh    String
  auth      String
  criadoEm  DateTime @default(now())
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
}

model AdminLoja {
  id        String  @id @default(cuid())
  usuarioId String
  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id])
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  @@unique([usuarioId, empresaId])
}

model Ponto {
  id           String              @id @default(cuid())
  dataHora     DateTime            @default(now())
  latitude     Float
  longitude    Float
  endereco     String?
  fotoUrl      String?
  tipo         String              @default("NORMAL")
  subTipo      String?
  descricao    String?
  origem       String              @default("APP") // APP | TOTEM
  totemId      String? // se origem=TOTEM, identifica o tablet
  usuarioId    String
  usuario      Usuario             @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  solicitacoes SolicitacaoAjuste[]

  @@index([usuarioId, dataHora])
  @@index([dataHora])
}

model SolicitacaoAjuste {
  id              String    @id @default(cuid())
  novoHorario     DateTime
  motivo          String
  status          String    @default("PENDENTE")
  tipo            String?
  usuarioId       String
  pontoId         String?
  criadoEm        DateTime  @default(now())
  ponto           Ponto?    @relation(fields: [pontoId], references: [id], onDelete: Cascade)
  usuario         Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  decididoPorId   String?
  decididoPorNome String?
  decididoEm      DateTime?

  @@index([usuarioId])
  @@index([status])
  @@index([pontoId])
}

model Ausencia {
  id             String   @id @default(cuid())
  dataInicio     DateTime
  dataFim        DateTime
  tipo           String
  motivo         String
  comprovanteUrl String?
  status         String   @default("PENDENTE")
  usuarioId      String
  criadoEm       DateTime @default(now())
  usuario        Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([status])
  @@index([dataInicio, dataFim])
}

model Feriado {
  id        String   @id @default(cuid())
  data      DateTime
  nome      String
  empresaId String?
  criadoEm  DateTime @default(now())
  empresa   Empresa? @relation(fields: [empresaId], references: [id])

  @@index([empresaId, data])
}

model LogAuditoria {
  id        String   @id @default(cuid())
  dataHora  DateTime @default(now())
  acao      String
  detalhes  String
  adminNome String
  adminId   String
  empresaId String

  @@index([empresaId, dataHora])
}

enum ModoValidacaoPonto {
  GPS
  PC_IP
}

model AsaasWebhookEvent {
  id        String   @id @default(cuid())
  event     String
  paymentId String
  // payload bruto (útil pra auditoria/debug)
  payload   Json
  createdAt DateTime @default(now())

  @@unique([event, paymentId])
  @@index([paymentId])
  @@map("asaas_webhook_event")
}

model LembretePush {
  id        String   @id @default(cuid())
  usuarioId String
  tipo      String // ALMOCO_5MIN | VOLTA_ALMOCO | SAIDA_5MIN | PAUSA_CAFE_EXCEDIDA
  data      String // "2026-03-13" (data em SP timezone)
  criadoEm  DateTime @default(now())

  @@unique([usuarioId, tipo, data])
  @@index([data])
  @@map("lembrete_push")
}

model HoraExtra {
  id              String    @id @default(cuid())
  usuarioId       String
  data            String // "YYYY-MM-DD"
  minutosExtra    Int // minutos além do expediente
  status          String    @default("PENDENTE") // PENDENTE | APROVADO | REJEITADO
  aprovadoPorId   String?
  aprovadoPorNome String?
  aprovadoEm      DateTime?
  criadoEm        DateTime  @default(now())
  usuario         Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, data])
}

model Revendedor {
  id            String   @id @default(cuid())
  nome          String
  logoUrl       String?
  nomeExibicao  String? // nome que aparece no sistema (ex: "PontoMax")
  corPrimaria   String?  @default("#7c3aed")
  corSecundaria String?  @default("#4f46e5")
  dominio       String?  @unique // "pontomax.com.br"
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now())

  // Billing por usuário ativo
  minimoMensal Float @default(199.90)
  faixa1Limite Int   @default(50) // até X usuários
  faixa1Valor  Float @default(6.00) // R$/usuário
  faixa2Limite Int   @default(150) // até X usuários
  faixa2Valor  Float @default(5.00) // R$/usuário
  faixa3Valor  Float @default(4.00) // R$/usuário (acima de faixa2Limite)

  usuarios Usuario[]
  empresas Empresa[]
}

model Analitico {
  id               String   @id @default(cuid())
  data             String   @unique // "YYYY-MM-DD" (timezone SP)
  visitasLanding   Int      @default(0)
  visitasSignup    Int      @default(0)
  signups          Int      @default(0)
  conversoes       Int      @default(0)
  visitantesUnicos Json? // hashes de IP para dedup diário
  criadoEm         DateTime @default(now())

  @@index([data])
  @@map("analitico")
}

model AjusteBancoHoras {
  id        String   @id @default(cuid())
  usuarioId String
  data      String // "YYYY-MM-DD" - data de referência (para débito no saldo)
  dataFolga String? // "YYYY-MM-DD" - data da folga (só para COMPENSACAO_FOLGA, reduz meta do dia)
  minutos   Int // positivo = crédito, negativo = débito
  tipo      String // PAGAMENTO_HE | COMPENSACAO_FOLGA | CORRECAO_MANUAL
  motivo    String
  adminId   String
  adminNome String
  criadoEm  DateTime @default(now())
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([data])
}

model Contracheque {
  id             String    @id @default(cuid())
  empresaId      String
  usuarioId      String
  mes            String // "2026-03" format
  arquivoUrl     String // URL do PDF
  nomeArquivo    String
  enviadoPorId   String
  enviadoPorNome String
  criadoEm       DateTime  @default(now())
  visualizado    Boolean   @default(false)
  visualizadoEm  DateTime?
  assinado       Boolean   @default(false)
  assinadoEm     DateTime?
  assinaturaUrl  String? // URL da assinatura digital do funcionário no momento da confirmação
  orientacao     String    @default("RETRATO") // RETRATO | PAISAGEM

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, mes])
  @@index([empresaId])
  @@index([usuarioId])
}

model Comunicado {
  id            String   @id @default(cuid())
  empresaId     String
  autorId       String
  autorNome     String
  titulo        String
  mensagem      String
  tipo          String   @default("AVISO") // AVISO | URGENTE | INFORMATIVO
  destinatarios Json? // null = todos, ["id1","id2"] = específicos
  criadoEm      DateTime @default(now())

  empresa  Empresa             @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  leituras LeituraComunicado[]

  @@index([empresaId])
  @@index([criadoEm])
}

model LeituraComunicado {
  id           String   @id @default(cuid())
  comunicadoId String
  usuarioId    String
  lidoEm       DateTime @default(now())

  comunicado Comunicado @relation(fields: [comunicadoId], references: [id], onDelete: Cascade)

  @@unique([comunicadoId, usuarioId])
  @@index([usuarioId])
}

model TotemDevice {
  id             String    @id @default(cuid())
  empresaId      String
  empresa        Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  nome           String // identificação humana: "Recepção", "Portaria"
  codigo         String?   @unique // código de pareamento de 6 dígitos (limpo após uso)
  codigoExpiraEm DateTime?
  token          String?   @unique // JWT longo, persiste no tablet
  pareadoEm      DateTime?
  ultimoUso      DateTime?
  ativo          Boolean   @default(true)
  criadoEm       DateTime  @default(now())

  @@index([empresaId])
  @@map("totem_device")
}

model Lead {
  id          String   @id @default(cuid())
  origem      String // 'AGENDAR_DEMO' | 'SIGNUP' | 'CONTATO' | etc
  nome        String
  email       String?
  whatsapp    String?
  empresa     String?
  cargo       String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  referrer    String?
  dadosExtras Json? // payload livre por origem (data/horário do agendamento, plano escolhido, etc)
  status      String   @default("NOVO") // NOVO | EM_CONTATO | QUALIFICADO | CONVERTIDO | DESCARTADO
  obs         String?
  criadoEm    DateTime @default(now())

  agendamentos Agendamento[]

  @@index([origem])
  @@index([status])
  @@index([criadoEm])
  @@map("lead")
}

model Agendamento {
  id             String   @id @default(cuid())
  dataHora       DateTime
  duracaoMinutos Int      @default(30)

  // PENDENTE | CONFIRMADO | REALIZADO | CANCELADO | NO_SHOW
  status String @default("PENDENTE")

  atendenteId String?

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  alteradoPor String?
  alteradoEm  DateTime?

  observacao String?
  criadoEm   DateTime @default(now())

  // Token público (não-sensível por si, só permite cancelar/reagendar 1 agendamento).
  // Anexado nos links de auto-gestão enviados ao lead.
  tokenAcesso String? @unique

  // Atribuição de marketing copiada do Lead na criação. Replicar aqui evita
  // join toda vez que o painel quer ver origem por agendamento.
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?

  // Evita duplicar disparo de mensagens em execuções repetidas do cron.
  confirmacaoEnviadaEm DateTime?
  lembreteEnviadoEm    DateTime?

  // Unicidade do slot é garantida por PARTIAL UNIQUE INDEX no Postgres
  // (criado via migration manual) — só vale pra status != 'CANCELADO',
  // permitindo reaproveitar o mesmo dataHora depois de um cancelamento.
  // Por isso aqui só `@@index`, não `@@unique`.
  @@index([status])
  @@index([leadId])
  @@index([dataHora])
  @@map("agendamento")
}

// =====================================================
// ===== MÓDULO FINANCEIRO (addon opcional) ============
// =====================================================

/// Lançamento de desconto pra um funcionário, vinculado a um mês de folha de pagamento.
/// Suporta parcelamento (cria N registros com mesmo lote, cada um em seu mês).
model Desconto {
  id                 String   @id @default(cuid())
  empresaId          String
  funcionarioId      String
  tipo               String   @default("OUTROS") // COMPRA | ADIANTAMENTO | VALE | EMPRESTIMO | OUTROS
  descricao          String
  valorOriginal      Decimal  @db.Decimal(10, 2)
  percentualDesconto Decimal? @db.Decimal(5, 2) // 0-100, abatimento sobre valorOriginal (ex.: 5 = 5%)
  valorFinal         Decimal  @db.Decimal(10, 2)
  mesReferencia      Int // 1-12 — mês em que entra na folha
  anoReferencia      Int // ex.: 2026
  parcelaAtual       Int      @default(1)
  parcelaTotal       Int      @default(1)
  loteId             String? // agrupa parcelas do mesmo lançamento
  observacao         String?
  criadoPorId        String?
  criadoPorNome      String?
  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt

  funcionario Usuario  @relation("desconto_funcionario", fields: [funcionarioId], references: [id], onDelete: Cascade)
  criadoPor   Usuario? @relation("desconto_criado_por", fields: [criadoPorId], references: [id])

  @@index([empresaId, anoReferencia, mesReferencia])
  @@index([funcionarioId, anoReferencia, mesReferencia])
  @@index([loteId])
}

/// Snapshot da folha de pagamento de um funcionário em um mês específico.
/// Criado quando admin clica "fechar folha" — congela valores e dispara push.
model FolhaPagamento {
  id             String    @id @default(cuid())
  empresaId      String
  funcionarioId  String
  mes            Int // 1-12
  ano            Int // ex.: 2026
  salarioBruto   Decimal   @default(0) @db.Decimal(10, 2)
  totalProventos Decimal   @default(0) @db.Decimal(10, 2) // hora extra etc. (opcional)
  totalDescontos Decimal   @default(0) @db.Decimal(10, 2)
  valorLiquido   Decimal   @default(0) @db.Decimal(10, 2)
  status         String    @default("RASCUNHO") // RASCUNHO | FECHADA | ASSINADA | RECUSADA | PAGA
  fechadaEm      DateTime?
  pagaEm         DateTime?
  comprovanteUrl String?
  observacao     String?
  /// JSON com snapshot detalhado: descontos individuais, saldo banco horas, etc.
  detalhamento   Json
  adminCriadorId String
  criadoEm       DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt

  // Assinatura do funcionário (espelha padrão de Fechamento de ponto)
  assinadoEm          DateTime?
  assinaturaUrl       String?
  ipAssinatura        String?
  userAgentAssinatura String?
  recusadoEm          DateTime?
  recusadoMotivo      String?

  funcionario  Usuario @relation("folha_funcionario", fields: [funcionarioId], references: [id], onDelete: Cascade)
  adminCriador Usuario @relation("folha_criada_por", fields: [adminCriadorId], references: [id])

  @@unique([funcionarioId, ano, mes])
  @@index([empresaId, ano, mes])
  @@index([status])
}

/// Lançamento de provento (crédito/acréscimo) pra um funcionário em um mês.
/// Ex.: salário do mês, periculosidade, adicional noturno, HE, comissão, bônus.
/// Suporta parcelamento (cria N registros agrupados por loteId).
model Provento {
  id            String   @id @default(cuid())
  empresaId     String
  funcionarioId String
  tipo          String   @default("OUTROS") // SALARIO | PERICULOSIDADE | ADICIONAL_NOTURNO | HORA_EXTRA | COMISSAO | BONUS | OUTROS
  descricao     String
  valor         Decimal  @db.Decimal(10, 2)
  mesReferencia Int // 1-12
  anoReferencia Int
  parcelaAtual  Int      @default(1)
  parcelaTotal  Int      @default(1)
  loteId        String?
  observacao    String?
  criadoPorId   String?
  criadoPorNome String?
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  funcionario Usuario  @relation("provento_funcionario", fields: [funcionarioId], references: [id], onDelete: Cascade)
  criadoPor   Usuario? @relation("provento_criado_por", fields: [criadoPorId], references: [id])

  @@index([empresaId, anoReferencia, mesReferencia])
  @@index([funcionarioId, anoReferencia, mesReferencia])
  @@index([loteId])
}
